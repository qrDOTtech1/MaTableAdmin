// Schema version: 1.3
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Restaurant {
  id                     String           @id @default(uuid())
  slug                   String?          @unique
  name                   String
  description            String?
  address                String?
  city                   String?
  postalCode             String?
  country                String?          @default("FR")
  phone                  String?
  email                  String?
  website                String?
  coverImageId           String?          @unique
  logoId                 String?          @unique
  acceptReservations     Boolean          @default(false)
  depositPerGuestCents   Int              @default(0)
  avgPrepMinutes         Int              @default(90)
  reservationLeadMinutes Int              @default(60)
  reservationSlotMinutes Int              @default(30)
  reservationPolicy      String?
  tipsEnabled            Boolean          @default(true)
  serviceCallEnabled     Boolean          @default(true)
  reviewsEnabled         Boolean          @default(true)
  // NovaTech IA Subscription
  subscription           SubscriptionPlan @default(STARTER)
  ollamaApiKey           String? // Clé API ollama.com (Bearer token)
  ollamaLangModel        String?          @default("gpt-oss:120b") // Modèle langage (chatbot, descriptions, planning)
  ollamaVisionModel      String?          @default("llama3.2-vision:11b") // Modèle vision (Magic Scan)
  subscriptionStartedAt  DateTime?
  subscriptionExpiresAt  DateTime?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @default(now()) @updatedAt

  users              User[]
  tables             Table[]
  menuItems          MenuItem[]
  servers            Server[]
  openingHours       OpeningHour[]
  reservations       Reservation[]
  serviceCalls       ServiceCall[]
  dishReviews        DishReview[]
  serverReviews      ServerReview[]
  stockMovements     StockMovement[]
  media              Media[]
  testimonial        Testimonial?
  generatedDocuments GeneratedDocument[]

  @@index([slug])
}

model User {
  id           String      @id @default(uuid())
  email        String      @unique
  passwordHash String? // nullable: shared DB with RSMATABLE (social users have no passwordHash)
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantId String? // nullable: social users are not tied to a restaurant
  createdAt    DateTime    @default(now())

  @@index([restaurantId])
}

model Table {
  id           String         @id @default(uuid())
  number       Int
  seats        Int            @default(2)
  label        String?
  restaurant   Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantId String
  sessions     TableSession[]
  orders       Order[]
  reservations Reservation[]
  serviceCalls ServiceCall[]
  createdAt    DateTime       @default(now())

  @@unique([restaurantId, number])
  @@index([restaurantId])
}

model TableSession {
  id              String        @id @default(uuid())
  table           Table         @relation(fields: [tableId], references: [id], onDelete: Cascade)
  tableId         String
  active          Boolean       @default(true)
  createdAt       DateTime      @default(now())
  closedAt        DateTime?
  billRequestedAt DateTime?
  billPaymentMode PaymentMode?
  tipCents        Int           @default(0)
  serverId        String?
  server          Server?       @relation(fields: [serverId], references: [id], onDelete: SetNull)
  orders          Order[]
  serviceCalls    ServiceCall[]

  @@index([tableId, active])
  @@index([serverId])
}

model Order {
  id         String       @id @default(uuid())
  table      Table        @relation(fields: [tableId], references: [id], onDelete: Cascade)
  tableId    String
  session    TableSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId  String
  server     Server?      @relation(fields: [serverId], references: [id], onDelete: SetNull)
  serverId   String?
  status     OrderStatus  @default(PENDING)
  items      Json
  totalCents Int
  tipCents   Int          @default(0)
  notes      String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  dishReviews   DishReview[]
  serverReviews ServerReview[]

  @@index([tableId])
  @@index([status, createdAt])
  @@index([sessionId])
  @@index([serverId])
}

model MenuItem {
  id                String     @id @default(uuid())
  restaurant        Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantId      String
  name              String
  description       String?
  priceCents        Int
  imageUrl          String?
  available         Boolean    @default(true)
  category          String?
  position          Int        @default(0)
  stockEnabled      Boolean    @default(false)
  stockQty          Int?
  lowStockThreshold Int?       @default(5)
  allergens         Allergen[] @default([])
  diets             Diet[]     @default([])
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @default(now()) @updatedAt

  modifierGroups ModifierGroup[]
  dishReviews    DishReview[]
  stockMovements StockMovement[]

  @@index([restaurantId])
  @@index([restaurantId, category])
}

model ModifierGroup {
  id         String           @id @default(uuid())
  menuItem   MenuItem         @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  menuItemId String
  name       String
  required   Boolean          @default(false)
  multiple   Boolean          @default(false)
  position   Int              @default(0)
  options    ModifierOption[]

  @@index([menuItemId])
}

model ModifierOption {
  id              String        @id @default(uuid())
  group           ModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId         String
  name            String
  priceDeltaCents Int           @default(0)
  position        Int           @default(0)
  available       Boolean       @default(true)

  @@index([groupId])
}

model Server {
  id           String            @id @default(uuid())
  name         String
  photoUrl     String?
  active       Boolean           @default(true)
  pin          String? // 4-digit PIN for server portal login
  restaurant   Restaurant        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantId String
  schedules    ServerSchedule[]
  sessions     TableSession[]
  orders       Order[]
  reviews      ServerReview[]
  notes        ServerNote[]
  challenges   ServerChallenge[]
  createdAt    DateTime          @default(now())

  @@index([restaurantId, active])
}

model ServerNote {
  id        String   @id @default(uuid())
  server    Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  serverId  String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([serverId])
}

model ServerChallenge {
  id        String    @id @default(uuid())
  server    Server    @relation(fields: [serverId], references: [id], onDelete: Cascade)
  serverId  String
  title     String
  done      Boolean   @default(false)
  dueDate   DateTime?
  createdAt DateTime  @default(now())

  @@index([serverId])
}

model ServerSchedule {
  id        String @id @default(uuid())
  server    Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  serverId  String
  dayOfWeek Int
  openMin   Int
  closeMin  Int

  @@index([serverId])
}

model OpeningHour {
  id           String     @id @default(uuid())
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantId String
  dayOfWeek    Int
  openMin      Int
  closeMin     Int
  service      String?

  @@index([restaurantId, dayOfWeek])
}

model DishReview {
  id           String     @id @default(uuid())
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantId String
  menuItem     MenuItem   @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  menuItemId   String
  order        Order?     @relation(fields: [orderId], references: [id], onDelete: SetNull)
  orderId      String?
  rating       Int
  comment      String?
  verified     Boolean    @default(true)
  createdAt    DateTime   @default(now())

  @@index([restaurantId, createdAt])
  @@index([menuItemId, createdAt])
}

model ServerReview {
  id           String     @id @default(uuid())
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantId String
  server       Server     @relation(fields: [serverId], references: [id], onDelete: Cascade)
  serverId     String
  order        Order?     @relation(fields: [orderId], references: [id], onDelete: SetNull)
  orderId      String?
  rating       Int
  comment      String?
  createdAt    DateTime   @default(now())

  @@index([serverId, createdAt])
  @@index([restaurantId, createdAt])
}

model ServiceCall {
  id           String        @id @default(uuid())
  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantId String
  table        Table         @relation(fields: [tableId], references: [id], onDelete: Cascade)
  tableId      String
  session      TableSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  sessionId    String?
  reason       String?
  createdAt    DateTime      @default(now())
  resolvedAt   DateTime?

  @@index([restaurantId, resolvedAt])
  @@index([tableId, resolvedAt])
}

model StockMovement {
  id           String     @id @default(uuid())
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantId String
  menuItem     MenuItem   @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  menuItemId   String
  delta        Int
  reason       String
  orderId      String?
  createdAt    DateTime   @default(now())

  @@index([restaurantId, createdAt])
  @@index([menuItemId, createdAt])
}

model Reservation {
  id              String     @id @default(uuid())
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantId    String
  table           Table?     @relation(fields: [tableId], references: [id], onDelete: SetNull)
  tableId         String?
  startsAt        DateTime
  durationMin     Int        @default(90)
  partySize       Int
  customerName    String
  customerEmail   String
  customerPhone   String?
  notes           String?
  status          String     @default("PENDING")
  depositCents    Int        @default(0)
  depositStatus   String     @default("NONE")
  stripeSessionId String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  cancelledAt     DateTime?

  @@index([restaurantId, startsAt])
  @@index([status, startsAt])
}

model Media {
  id           String     @id @default(uuid())
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantId String
  mimeType     String
  bytes        Bytes
  size         Int
  originalName String?
  sha256       String?
  createdAt    DateTime   @default(now())

  @@index([restaurantId])
}

model Testimonial {
  id           String     @id @default(uuid())
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantId String     @unique
  displayName  String
  displayRole  String?
  quote        String
  rating       Int        @default(5)
  published    Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([published, updatedAt])
}

enum OrderStatus {
  PENDING
  COOKING
  SERVED
  PAID
  CANCELLED
}

enum PaymentMode {
  CARD
  CASH
  COUNTER
}

enum Allergen {
  GLUTEN
  CRUSTACEANS
  EGGS
  FISH
  PEANUTS
  SOYBEANS
  MILK
  NUTS
  CELERY
  MUSTARD
  SESAME
  SULPHITES
  LUPIN
  MOLLUSCS
}

enum Diet {
  VEGETARIAN
  VEGAN
  GLUTEN_FREE
  LACTOSE_FREE
  HALAL
  KOSHER
  PORK_FREE
  LOW_CAL
  SPICY
}

enum SubscriptionPlan {
  STARTER // 49,99€/mois — 30 tables, fonctions de base
  PRO // 139,99€/mois — tables illimitées, analytics, export Z
  PRO_IA // 299€/mois — tout PRO + NovaTech IA (Magic Scan, Chatbot, Planning IA)
}

// ---------------------------------------------------------------------------
// Prospection CRM
// ---------------------------------------------------------------------------
model Prospect {
  id           String    @id @default(uuid())
  name         String
  city         String?
  address      String?
  phone        String?
  email        String?
  description  String?   @db.Text
  website      String?
  category     String?
  imageUrl     String?
  sourceUrl    String?
  status       String    @default("NEW") // NEW | CONTACTED | ACTIVATED | IGNORED
  restaurantId String?
  notes        String?
  activatedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now()) @updatedAt

  @@index([status])
  @@index([city])
}

// ---------------------------------------------------------------------------
// Inbound Emails
// ---------------------------------------------------------------------------
model ReceivedEmail {
  id        String   @id @default(uuid())
  from      String
  to        String
  subject   String
  text      String?  @db.Text
  html      String?  @db.Text
  createdAt DateTime @default(now())

  @@index([to])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Demandes de souscription (formulaire /tarifs côté landing)
// ---------------------------------------------------------------------------
model PricingRequest {
  id              String    @id @default(uuid())
  status          String    @default("NEW") // NEW | CONTACTED | CONVERTED | REJECTED
  restaurantName  String
  managerName     String
  email           String
  phone           String?
  city            String?
  selectedModules String[]  @default([])
  engagement      String    // "3m" | "6m" | "9m" | "12m" | "12a"
  monthlyHtCents  Int       @default(0)
  totalHtCents    Int       @default(0)
  volumePercent   Int       @default(0)
  message         String?   @db.Text
  sourceUrl       String?
  convertedRestaurantId String?
  convertedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now()) @updatedAt

  @@index([status, createdAt])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Documents générés (classeur virtuel)
// ---------------------------------------------------------------------------
model GeneratedDocument {
  id              String     @id @default(uuid())
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantId    String
  type            String // 'contrat' | 'prestation' | 'devis' | 'facture' | 'cgvu' | 'onboarding' | 'tarification'
  number          String // ex. "CONT-2026-042"
  title           String // libellé lisible "Contrat — Le Bistrot du Coin"
  totalCents      Int        @default(0) // 0 si non applicable (cgvu, onboarding, tarification)
  vendor          Json // snapshot prestataire au moment de la génération
  client          Json // snapshot client
  data            Json // tout l'état du formulaire (engagement, prestation, docMeta, ...)
  pdfUrl          String? // URL S3/CDN — optionnel, on stocke d'abord les données seules
  signedAt        DateTime? // si le doc est signé physiquement
  createdAt       DateTime   @default(now())
  createdBy       String? // username admin
  archivedInMonth String? // "2026-04" — set quand le doc a été inclus dans un envoi archive mensuel

  @@index([restaurantId, createdAt])
  @@index([type, createdAt])
  @@index([createdAt])
  @@index([archivedInMonth])
}

// ---------------------------------------------------------------------------
// Configuration admin globale (singleton)
// ---------------------------------------------------------------------------
model AdminConfig {
  id                String    @id @default("default")
  archiveRecipient  String? // email destinataire des archives mensuelles
  archiveEnabled    Boolean   @default(false)
  archiveDayOfMonth Int       @default(1) // jour du mois pour l'envoi
  lastArchiveSentAt DateTime?
  // Backup DB quotidien
  backupRecipient   String?   // email où envoyer les backups
  backupEnabled     Boolean   @default(false)
  backupHourUtc     Int       @default(3)  // heure UTC du backup quotidien (0-23)
  lastBackupAt      DateTime?
  lastBackupSize    Int?      // taille du dernier dump en bytes
  lastBackupTables  Int?      // nb de tables sauvegardées
  lastBackupRows    Int?      // nb total de lignes sauvegardées
  updatedAt         DateTime  @updatedAt
}
