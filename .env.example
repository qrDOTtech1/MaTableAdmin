# Variables nécessaires pour MaTable Admin
# À copier dans Railway > Variables

# Format: pseudo:motdepasse (plusieurs possibles séparés par une virgule)
ADMIN_CREDENTIALS=admin:admin1234

# Une clé longue et aléatoire pour les cookies de session
JWT_SECRET=generer-une-cle-securisee-ici

# URL de la base de données Postgres (la même que MaTable-API)
DATABASE_URL=postgresql://user:pass@host:port/dbname

# URL de l'API Backend (MaTable-API) pour les opérations de gestion
NEXT_PUBLIC_API_URL=https://votre-api-railway.up.railway.app

# Secret partagé entre Admin et API pour lancer le scraper à distance
# Recommandé: même valeur que JWT_SECRET côté Admin et côté API
ADMIN_SCRAPER_SECRET=change-moi-par-le-meme-secret-que-sur-l-api

# Resend API Key (pour envoyer des emails depuis @matable.pro)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
